PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/arduino_iot
JWT_SECRET=change_me_to_long_random_secret
GROK_API_KEY=your_grok_key
GROK_MODEL=grok-2-latest
AI_BASE_URL=
CLIENT_ORIGIN=*,http://localhost:5000,http://localhost:3000,https://your-frontend.vercel.app
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
TEACHER_SETUP_CODE=one_time_teacher_setup_code
TEACHER_MAX_ACCOUNTS=6

# ------------------------------
# DEPLOY CHEAT SHEET
# ------------------------------
# Render (Backend API)
# Root Directory: .
# Build Command: npm install
# Start Command: npm start
# Health Check Path: /api/health
#
# Vercel (Frontend)
# Root Directory: frontend
# Framework Preset: Other
# Build Command: (empty)
# Output Directory: (empty)
#
# NOTE:
# frontend/vercel.json ішінде https://your-render-service.onrender.com
# мәнін өзіңіздің нақты Render URL-ге ауыстырыңыз.
